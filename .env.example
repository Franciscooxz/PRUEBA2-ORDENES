# Copia este archivo a .env y completa con tus valores.
# .env está en .gitignore: NO se sube al repositorio.

# Cadena de conexión a PostgreSQL.
DATABASE_URL=postgres://postgres:TU_PASSWORD@localhost:5432/wind_orders?sslmode=disable

# Secreto para firmar los JWT (usa un valor largo y aleatorio en producción).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Puerto del servidor (opcional, por defecto 8080).
PORT=8080
